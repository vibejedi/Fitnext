# ---- Supabase (backend: auth + database + storage) ----
# Create a free project at https://supabase.com, then Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Claude (live AI coach). Without this the coach runs in demo/mock mode. ----
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6)
FITNEXT_MODEL=claude-sonnet-4-6
